# Server Configuration
PORT=3001
HOST=0.0.0.0

# Server read, write, and idle connection timeouts (seconds)
SERVER_READ_TIMEOUT=600
SERVER_WRITE_TIMEOUT=1200
SERVER_IDLE_TIMEOUT=300
SERVER_GRACEFUL_SHUTDOWN_TIMEOUT=10

# Slave node identifier
IS_SLAVE=false

# Timezone
TZ=Asia/Jakarta

# Authentication configuration - required to protect admin API and UI
AUTH_KEY=authandda # IMPORTANT: Change this to a strong, unique key!

# Database configuration - default is SQLite at ./data/gpt-load.db
# PostgreSQL example:
DATABASE_DSN=postgres://postgres:123456@postgres:5432/gpt-load?sslmode=disable

# Redis configuration - default is in-memory storage
REDIS_DSN=redis://redis:6379/0

# Concurrency limit
MAX_CONCURRENT_REQUESTS=20000

# CORS configuration
ENABLE_CORS=true
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=false

# Log configuration
LOG_LEVEL=info
LOG_FORMAT=text
LOG_ENABLE_FILE=true
LOG_FILE_PATH=./data/logs/app.log
